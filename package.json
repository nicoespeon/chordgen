{
  "name": "chordgen",
  "version": "0.1.0",
  "description": "Generate Karabiner-Elements chording rules from BÉPO TSV chord lists",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx src/build.ts",
    "disable": "tsx src/disable.ts",
    "stats": "tsx src/stats.ts",
    "analyze": "tsx src/analyze.ts",
    "practice": "tsx src/practice.ts",
    "sort": "tsx src/sort.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm sort && git add chords/*.tsv"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
